# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning the repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Backend API URLs (optional)
# Leave NEXT_PUBLIC_BACKEND_BASE_URL unset so the browser uses same-origin /api/*
# (required for Docker Compose: only nginx :2026 is published, not gateway :8001).
# If you must set it, use the URL you open in the browser, e.g. http://localhost:2026.
# NEXT_PUBLIC_BACKEND_BASE_URL="http://localhost:2026"
# Direct LangGraph (local dev without nginx) only:
# NEXT_PUBLIC_LANGGRAPH_BASE_URL="http://localhost:2024"
